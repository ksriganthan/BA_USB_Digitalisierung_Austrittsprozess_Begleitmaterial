          <bpmn:sequenceFlow id="Flow_1xfsyt6" sourceRef="Activity_0qyg0ut" targetRef="Gateway_0zjbvlb" />
          <bpmn:sequenceFlow id="Flow_19jaja2" sourceRef="Gateway_0zjbvlb" targetRef="Activity_0gna8ar" />
          <bpmn:textAnnotation id="TextAnnotation_1u1vxmy">
            <bpmn:text>Quartalsweise erhalten Führungspersonen für Mitarbeitende, die demnächst einen runden Geburtstag feiern, Pro-Innerstadt-Bons als späteres Geschenk. Im Rahmen der Austrittsbearbeitung wird geprüft, ob für die austretende Person bereits ein Bon ausgegeben wurde. Ist dies der Fall, wird der Bon bei der zuständigen Führungsperson zurückgefordert.</bpmn:text>
          </bpmn:textAnnotation>
          <bpmn:textAnnotation id="TextAnnotation_1mumyjw">
            <bpmn:text>HR Administration erhält den Bon zurück und dokumentiert den Eingang in einer intern geführten Liste. Am Jahresende wird diese Liste an die Leitung HR Operations weitergeleitet.</bpmn:text>
          </bpmn:textAnnotation>
          <bpmn:textAnnotation id="TextAnnotation_0jepkk2">
            <bpmn:text>Die Anfrage soll gemäss Susan getrackt werden, aber es ist nicht genau definiert.</bpmn:text>
          </bpmn:textAnnotation>
          <bpmn:association id="Association_0k2qwdd" associationDirection="None" sourceRef="Activity_0gna8ar" targetRef="TextAnnotation_1mumyjw" />
          <bpmn:association id="Association_1gx1xxl" associationDirection="None" sourceRef="TextAnnotation_1u1vxmy" targetRef="Activity_0qyg0ut" />
          <bpmn:association id="Association_1otxmmj" associationDirection="None" sourceRef="Activity_0qyg0ut" targetRef="TextAnnotation_0jepkk2" />
        </bpmn:subProcess>
