<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_0hcg2zp" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.43.1" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.24.0">
  <bpmn:collaboration id="Collaboration_0mxnk8w">
    <bpmn:participant id="Participant_15dncnp" name="Direktion Personal" processRef="Process_1er3oko" />
    <bpmn:textAnnotation id="TextAnnotation_0ojp10l">
      <bpmn:text>Ordentliche / Frühzeitige Pensionierung</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1htnvht">
      <bpmn:text>Per Jahresende wird eine Liste aller Mitarbeitenden erstellt, die im Folgejahr mindestens 58 Jahre alt sind oder dieses Alter erreichen. Die zuständigen Führungspersonen werden auf eine mögliche Pensionierung der betreffenden Mitarbeitenden hingewiesen. Dies dient einerseits der frühzeitigen Planung des Karriereendes und andererseits der Vorbereitung einer allfälligen Wiederbesetzung.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1gek6ay">
      <bpmn:text>Die Führungsperson reagiert in der Regel nicht aktiv auf diese Meldung.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_13se708">
      <bpmn:text>Eine mögliche Optimierung besteht darin, pensionierungsnahe Mitarbeitende proaktiv anzusprechen. Alternativ könnte die ordentliche Pensionierung als Standardfall definiert werden, sodass nur abweichende Fälle wie Frühpensionierung oder Weiterbeschäftigung aktiv gemeldet werden müssen.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1yqe5s8">
      <bpmn:text>Es gibt noch kein Feld für die ordentliche Pensionierung</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_03xz7q7">
      <bpmn:text>Eine bevorstehende Pensionierung wird meistens durch die mitarbeitende Person selbst mitgeteilt.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0e62kl9" associationDirection="None" sourceRef="Event_1esad3q" targetRef="TextAnnotation_1gek6ay" />
    <bpmn:association id="Association_0bhl8bc" associationDirection="None" sourceRef="Activity_0u4o0ib" targetRef="TextAnnotation_1yqe5s8" />
    <bpmn:association id="Association_1yrrmlf" associationDirection="None" sourceRef="Event_1l4dujy" targetRef="TextAnnotation_03xz7q7" />
    <bpmn:association id="Association_0bo4t3r" associationDirection="None" sourceRef="TextAnnotation_1htnvht" targetRef="Event_10j3nzs" />
    <bpmn:association id="Association_19an5m4" associationDirection="None" sourceRef="Event_1esad3q" targetRef="TextAnnotation_13se708" />
  </bpmn:collaboration>
