      <bpmn:textAnnotation id="TextAnnotation_1ogcpkd">
        <bpmn:text>Es ist sehr unwahrscheinlich, dass jemand vor der Pensionierung eine Weiterbildung macht. Deshalb entfällt hier die Rückzahlungspflicht.</bpmn:text>
      </bpmn:textAnnotation>
