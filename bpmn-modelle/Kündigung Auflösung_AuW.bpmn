<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_0hcg2zp" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.43.1" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.24.0">
  <bpmn:collaboration id="Collaboration_0mxnk8w">
    <bpmn:participant id="Participant_15dncnp" name="Direktion Personal" processRef="Process_1er3oko" />
    <bpmn:textAnnotation id="TextAnnotation_0ojp10l">
      <bpmn:text>Kündigung MA / AG / Auflösung - AuW</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1nmey1s">
      <bpmn:text>SAP-Erfassung und die Rücksendung des Austrittsscheins sind fachlich getrennte Folgehandlungen</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1l141ij">
      <bpmn:text>Wird an HR AuW versendet</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0f9qfjg">
      <bpmn:text>Vor einer arbeitgeberseitigen Auflösung erfolgen situative Abklärungen wie Vorgespräche, Verwarnungen und bei Lehrverträgen gegebenenfalls Elterngespräche. Diese Schritte sind einzelfallabhängig.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_168nlvu">
      <bpmn:text>Umfasst Kündigung AG, Auflösung sowie Beendigungen bei Lehrverträgen. Bei Lehrverträgen wird keine klassische Kündigung MA vorgenommen, sondern das Lehrverhältnis aufgelöst.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1yux0td">
      <bpmn:text>Bei anderen Ausbildungsverhältnissen kann auch eine Kündigung durch die mitarbeitende Person erfolgen.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_032gdmv">
      <bpmn:text>Die Bildungsverantwortlichen erhalten von der Bildungsbehörde eine Mitteilung über das Nichtbestehen der Prüfung. Dadurch ist eine Weiterbeschäftigung nicht möglich. Die Remonstrationsfrist beträgt zehn Tage.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_00bo3rt" associationDirection="None" sourceRef="Event_1ih9s3b" targetRef="TextAnnotation_1yux0td" />
    <bpmn:association id="Association_00r0izr" associationDirection="None" sourceRef="Event_0vp41pp" targetRef="TextAnnotation_032gdmv" />
    <bpmn:association id="Association_0q4qywd" associationDirection="None" sourceRef="Event_0kduudh" targetRef="TextAnnotation_168nlvu" />
    <bpmn:association id="Association_1hstnan" associationDirection="None" sourceRef="Event_0kduudh" targetRef="TextAnnotation_0f9qfjg" />
    <bpmn:association id="Association_1nz7rdc" associationDirection="None" sourceRef="Event_0xxyv1g" targetRef="TextAnnotation_1nmey1s" />
    <bpmn:textAnnotation id="TextAnnotation_1pyul72">
      <bpmn:text>Die Auflösung infolge Nichtbestehens HF-Prüfungen benötigt Unterschriften von Leitung Ausbildung, BV und MA</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0o80n2t">
      <bpmn:text>Die zusätzliche Auflösungserklärung erscheint ineffizient, da der Anstellungsvertrag bereits eine Klausel enthält, wonach das Anstellungsverhältnis bei Nichtbestehen der Prüfung endet.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0tfr33a">
      <bpmn:text>Eine mögliche Vereinfachung wird bereits durch die Leitung Ausbildung und den Rechtsdienst geprüft.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1ymcsxw" associationDirection="None" sourceRef="Activity_0duj13a" targetRef="TextAnnotation_0tfr33a" />
    <bpmn:association id="Association_11fmfko" associationDirection="None" sourceRef="Activity_0duj13a" targetRef="TextAnnotation_1pyul72" />
    <bpmn:association id="Association_0y88gab" associationDirection="None" sourceRef="Activity_0duj13a" targetRef="TextAnnotation_0o80n2t" />
    <bpmn:textAnnotation id="TextAnnotation_0ywszgx">
      <bpmn:text>Ohne Genehmigung durch die Ausbildungsbehörde erfolgt keine arbeitgeberseitige Auflösung.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_16nutzo" associationDirection="None" sourceRef="Activity_1vytoei" targetRef="TextAnnotation_0ywszgx" />
    <bpmn:association id="Association_0vehzyf" associationDirection="None" sourceRef="Activity_0duj13a" targetRef="TextAnnotation_1l141ij" />
  </bpmn:collaboration>
