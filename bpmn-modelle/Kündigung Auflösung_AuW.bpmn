      <bpmn:task id="Activity_0phedc9" name="Laufende Familienzulagen prüfen">
        <bpmn:incoming>Flow_04i7nmo</bpmn:incoming>
        <bpmn:outgoing>Flow_1dgrdqa</bpmn:outgoing>
      </bpmn:task>
      <bpmn:sequenceFlow id="Flow_04i7nmo" sourceRef="Gateway_12158wi" targetRef="Activity_0phedc9" />
      <bpmn:sequenceFlow id="Flow_1dgrdqa" sourceRef="Activity_0phedc9" targetRef="Activity_0ytot63" />
      <bpmn:textAnnotation id="TextAnnotation_1wt8dl9">
        <bpmn:text>Kündigungs- oder Auflösungs-datum und Kündigungs- oder Auflösungs-grund hinterlegen</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_1npw47q">
        <bpmn:text>Eine manuelle PKBS-Meldung erfolgt bei stornierten, verschobenen, rückwirkenden oder langzeitkranken Austritten sowie bei Pensionierungen. Bei 1.-Klasse-Zusatzversicherung ist zusätzlich eine UVK-Abmeldung zu prüfen.</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_1koi0pl">
        <bpmn:text>HR Payroll muss im SAP, E-Dossier und in den verknüpften Tickets recherchieren</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0o0trht">
        <bpmn:text>Bei einer Meldung durch HR Administration wird im Ticket zusätzlich vermerkt, ob eine Rückzahlungspflicht besteht.</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_1ae4y08">
        <bpmn:text>Bei Lehrverträgen besteht keine Rückzahlungspflicht. Bei HF-Ausbildungen kann für Quereinsteigende eine Rückzahlungspflicht bestehen. Diese entfällt, wenn nach Abschluss keine Anschlussanstellung angeboten werden kann. In den übrigen Fällen bleibt die Rückzahlungspflicht gemäss Anstellungsvertrag bestehen.</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_1rnu4v6">
        <bpmn:text>Nur relevant, wenn die austretende Person pensionskassenpflichtig war.</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_1rcqmav">
        <bpmn:text>Bei Unklarheiten Rücksprache mit HR AuW oder BV</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_156zlof" associationDirection="None" sourceRef="Gateway_1nrm5j2" targetRef="TextAnnotation_1npw47q" />
      <bpmn:association id="Association_0d075zf" associationDirection="None" sourceRef="Gateway_1nrm5j2" targetRef="TextAnnotation_1rnu4v6" />
      <bpmn:association id="Association_1pxnf3w" associationDirection="None" sourceRef="TextAnnotation_0o0trht" targetRef="Gateway_0y4fqkr" />
      <bpmn:association id="Association_1cctsgz" associationDirection="None" sourceRef="Gateway_0y4fqkr" targetRef="TextAnnotation_1ae4y08" />
      <bpmn:association id="Association_0b1tivr" associationDirection="None" sourceRef="Activity_00j0tj2" targetRef="TextAnnotation_1koi0pl" />
      <bpmn:association id="Association_1xud11a" associationDirection="None" sourceRef="Activity_00j0tj2" targetRef="TextAnnotation_1rcqmav" />
      <bpmn:association id="Association_0j88wm5" associationDirection="None" sourceRef="TextAnnotation_1wt8dl9" targetRef="Activity_0vabasf" />
      <bpmn:textAnnotation id="TextAnnotation_1m8gkhg">
        <bpmn:text>Kein Workflow</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_0ellkue" associationDirection="None" sourceRef="Event_0bp0wie" targetRef="TextAnnotation_1m8gkhg" />
    </bpmn:subProcess>
