      <bpmn:sequenceFlow id="Flow_1ik12mt" sourceRef="Activity_0bvm2vo" targetRef="Gateway_0bfioxb" />
      <bpmn:sequenceFlow id="Flow_1st0fcc" sourceRef="Gateway_0bfioxb" targetRef="Event_0ta8mvb" />
      <bpmn:textAnnotation id="TextAnnotation_015kiwp">
        <bpmn:text>ggf. Mehrarbeit</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0zmsslh">
        <bpmn:text>Der Austrittsschein enthält auszuzahlende oder zu verrechnende Guthaben wie Ferien, Flexitage, Überstunden, Dienstjubiläumsanspruch und ggf. Schichtbonus. Die Verarbeitung erfolgt nach Prüfung durch HR Time Management.</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0jqukz1">
        <bpmn:text>**HR Payroll geht dem Austrittsschein nicht aktiv nach.** Erst bei MA-Rückfrage zur ausstehenden Auszahlung wird klar, dass Schein noch bei FV pendent ist.</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_1a87kiz">
        <bpmn:text>Es kommt auch vor, dass MA sich beschweren, wenn der Austrittsschein andere Entscheidungen beinhaltet als die, welche mit FV besprochen wurden</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_09ry4vm" associationDirection="None" sourceRef="Activity_0z46f1g" targetRef="TextAnnotation_0jqukz1" />
      <bpmn:association id="Association_00x49zz" associationDirection="None" sourceRef="Activity_0z46f1g" targetRef="TextAnnotation_1a87kiz" />
      <bpmn:association id="Association_1ftpvc4" associationDirection="None" sourceRef="Gateway_1frj13b" targetRef="TextAnnotation_015kiwp" />
      <bpmn:association id="Association_1wdg7gt" associationDirection="None" sourceRef="Flow_16ch7bn" targetRef="TextAnnotation_0zmsslh" />
    </bpmn:subProcess>
