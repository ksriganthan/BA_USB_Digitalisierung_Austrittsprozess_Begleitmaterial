      <bpmn:sequenceFlow id="Flow_0is6v5e" sourceRef="Gateway_1jqu31f" targetRef="Event_1gd8krg" />
      <bpmn:textAnnotation id="TextAnnotation_16237n2">
        <bpmn:text>ggf. Mehrarbeit</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_17uvp28">
        <bpmn:text>Der Austrittsschein enthält auszuzahlende oder zu verrechnende Guthaben wie Ferien, Flexitage, Überstunden, Dienstjubiläumsanspruch und ggf. Schichtbonus. Die Verarbeitung erfolgt nach Prüfung durch HR Time Management.</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0jqukz1">
        <bpmn:text>**HR Payroll geht dem Austrittsschein nicht aktiv nach.** Erst bei MA-Rückfrage zur ausstehenden Auszahlung wird klar, dass Schein noch bei FV pendent ist.</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_1a87kiz">
        <bpmn:text>Es kommt auch vor, dass MA sich beschweren, wenn der Austrittsschein andere Entscheidungen beinhaltet als die, welche mit FV besprochen wurden</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_09ry4vm" associationDirection="None" sourceRef="Activity_1p0763z" targetRef="TextAnnotation_0jqukz1" />
      <bpmn:association id="Association_00x49zz" associationDirection="None" sourceRef="Activity_1p0763z" targetRef="TextAnnotation_1a87kiz" />
      <bpmn:association id="Association_08nz9js" associationDirection="None" sourceRef="Gateway_0yrrzen" targetRef="TextAnnotation_16237n2" />
      <bpmn:association id="Association_19bmqt9" associationDirection="None" sourceRef="Flow_1l5qkkl" targetRef="TextAnnotation_17uvp28" />
    </bpmn:subProcess>
