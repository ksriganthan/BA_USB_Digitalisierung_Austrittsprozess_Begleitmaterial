      <bpmn:dataStoreReference id="DataStoreReference_0osrdk3" name="UKA" />
      <bpmn:dataObjectReference id="DataObjectReference_0hppxd0" name="Austrittsschein" dataObjectRef="DataObject_15rf5xl" />
      <bpmn:dataObject id="DataObject_15rf5xl" />
      <bpmn:dataStoreReference id="DataStoreReference_0njm6kk" name="Jira" />
      <bpmn:dataStoreReference id="DataStoreReference_18pgc9n" name="Jira" />
      <bpmn:textAnnotation id="TextAnnotation_06fybw7">
        <bpmn:text>Ferien, Flex, Überstunden, Dienstjubiläum</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_0gtufu9" associationDirection="None" sourceRef="Activity_0fxbvyp" targetRef="TextAnnotation_06fybw7" />
      <bpmn:textAnnotation id="TextAnnotation_01zxzp6">
        <bpmn:text>HR Time Management wartet häufig bis nach dem Austrittsdatum, da sich PEP-Salden bis dahin verändern können. Eine Vorabbearbeitung ist möglich, wenn die austretende Person vor dem Austritt Ferien bezieht.</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1gmrh7z" associationDirection="None" sourceRef="Gateway_1in1ipe" targetRef="TextAnnotation_01zxzp6" />
      <bpmn:textAnnotation id="TextAnnotation_0ys5eop">
        <bpmn:text>Fehlende Unterschriften führen zu manuellem Zusatzaufwand, da der Austrittsschein heruntergeladen, kommentiert, erneut hochgeladen und zurückgesendet werden muss.</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_0xlvvb3" associationDirection="None" sourceRef="Activity_0du5z3d" targetRef="TextAnnotation_0ys5eop" />
      <bpmn:textAnnotation id="TextAnnotation_192da7q">
        <bpmn:text>Abweichungen entstehen insbesondere dann, wenn nach dem Ausfüllen des Austrittsscheins noch Änderungen in PEP vorgenommen werden. In diesem Fall bleibt das Ticket pendent, bis die Angaben korrigiert sind.</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1oo7f13" associationDirection="None" sourceRef="Gateway_1in1ipe" targetRef="TextAnnotation_192da7q" />
      <bpmn:textAnnotation id="TextAnnotation_17zw92v">
        <bpmn:text>Ausbuchen bedeutet hier, die im Austrittsschein definierten auszuzahlenden oder zu verrechnenden Salden im PEP auf null bzw. entsprechend zu korrigieren.</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_0hj86gk" associationDirection="None" sourceRef="Activity_0t11s97" targetRef="TextAnnotation_17zw92v" />
      <bpmn:textAnnotation id="TextAnnotation_1y7jmby">
        <bpmn:text>Bei Teilaustritt dürfen Ferien nicht ausbezahlt werden</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_0upi80c" associationDirection="None" sourceRef="Activity_0fxbvyp" targetRef="TextAnnotation_1y7jmby" />
      <bpmn:textAnnotation id="TextAnnotation_1rebd86">
        <bpmn:text>Zeugnisse prüfen, Versicherung informieren und Taggelder bis zum Austritt abrechnen</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_06mywt4" associationDirection="None" sourceRef="Activity_1hcdwbr" targetRef="TextAnnotation_1rebd86" />
    </bpmn:subProcess>
