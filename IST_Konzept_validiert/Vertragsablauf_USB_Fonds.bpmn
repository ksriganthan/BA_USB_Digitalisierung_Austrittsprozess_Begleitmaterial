<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_0hcg2zp" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.43.1" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.24.0">
  <bpmn:collaboration id="Collaboration_0mxnk8w">
    <bpmn:participant id="Participant_15dncnp" name="Direktion Personal" processRef="Process_1er3oko" />
    <bpmn:textAnnotation id="TextAnnotation_0ojp10l">
      <bpmn:text>Vertragsablauf - USB / Fonds</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_06uu64m">
      <bpmn:text>Unter anderem wird der Austrittsschein versendet</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1nmey1s">
      <bpmn:text>SAP-Erfassung und die Rücksendung des Austrittsscheins sind fachlich getrennte Folgehandlungen</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1htnvht">
      <bpmn:text>Es wird quartalsweise eine Liste gezogen mit befristeten Verträgen. Die FV werden angeschrieben mit der Frage, ob sie den Vertrag verlängern möchten. Falls die Antwort nein ist, ist dies das Startereignis des Vertragsablauf Austrittsprozess.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1tv5duh">
      <bpmn:text>Bei Workflow-Vertragsabläufe (Fonds, ZTP, Hotellerie, Personal) erfolgt dies automatisch durch den Workflow</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_191i3um">
      <bpmn:text>Bei Workflow-Abläufen wird kein Formular ausgefüllt</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1g8e97t">
      <bpmn:text>Bei Workflow wird bei einer Entscheidung gegen eine Verlängerung ein Ticket von HR Administration erstellt</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0ifhm1q">
      <bpmn:text>HR Beratung ist bei Vertragsabläufen nicht involviert ?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0ia4m5h">
      <bpmn:text>Oft erhält Payroll die Austrittsmeldungen mehrfach z.B. HR Admin, HR Beratung, FV. Manchmal auch mehrfach von der gleichen Stelle</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0t1j7t2" associationDirection="None" sourceRef="Activity_18w0qzb" targetRef="TextAnnotation_06uu64m" />
    <bpmn:association id="Association_1nz7rdc" associationDirection="None" sourceRef="Event_0xxyv1g" targetRef="TextAnnotation_1nmey1s" />
    <bpmn:association id="Association_0bo4t3r" associationDirection="None" sourceRef="TextAnnotation_1htnvht" targetRef="Event_10j3nzs" />
