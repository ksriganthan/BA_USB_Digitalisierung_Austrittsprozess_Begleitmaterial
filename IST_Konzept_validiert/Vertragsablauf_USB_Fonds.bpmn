        <bpmn:textAnnotation id="TextAnnotation_0wad5r5">
          <bpmn:text>Relevant bei Personen ab 58 Jahren; bei möglicher Frühpensionierung erfolgt Rücksprache mit HR Beratung.</bpmn:text>
        </bpmn:textAnnotation>
        <bpmn:textAnnotation id="TextAnnotation_1slbnsp">
          <bpmn:text>Auf Listen eintragen</bpmn:text>
        </bpmn:textAnnotation>
        <bpmn:association id="Association_1q4mrp4" associationDirection="None" sourceRef="TextAnnotation_0wad5r5" targetRef="Gateway_1hoc0mx" />
        <bpmn:association id="Association_0uu6j0t" associationDirection="None" sourceRef="Activity_0eovd4k" targetRef="TextAnnotation_1slbnsp" />
        <bpmn:textAnnotation id="TextAnnotation_021kmjd">
          <bpmn:text>In SMU-Bearbeitung überführt</bpmn:text>
        </bpmn:textAnnotation>
        <bpmn:association id="Association_00c5bbq" associationDirection="None" sourceRef="Flow_08ky4jy" targetRef="TextAnnotation_021kmjd" />
        <bpmn:textAnnotation id="TextAnnotation_1pedl3d">
          <bpmn:text>Mehr als 120 T krank bei 100%</bpmn:text>
        </bpmn:textAnnotation>
        <bpmn:association id="Association_0w6cbrn" associationDirection="None" sourceRef="Gateway_0d3kj3i" targetRef="TextAnnotation_1pedl3d" />
        <bpmn:textAnnotation id="TextAnnotation_1a51ivu">
          <bpmn:text>Bei Workflow-Vertragsablauf: Printscreen an PA, um den Fall im Workflow abzuschliessen</bpmn:text>
        </bpmn:textAnnotation>
        <bpmn:association id="Association_1hwkv2l" associationDirection="None" sourceRef="Event_1fvtdfr" targetRef="TextAnnotation_1a51ivu" />
        <bpmn:textAnnotation id="TextAnnotation_0w6bym9">
          <bpmn:text>Noch vor zwei Jahren gab es Fälle, bei denen eine Anstellungsnummer (4xxxxxxx) mehrere Anstellungen umfasste. Beispiel: Die Anstellung 400001410 hat ein Pensum von 100 %, das auf die Anstellungen A und B mit jeweils 50 % aufgeteilt ist. Wenn die Person nur eine der Anstellungen kündigt, wird das Pensum in PEP nicht angepasst. Deshalb ist eine Meldung an die HR-Absenzen erforderlich, um dies manuell in PEP anzupassen.</bpmn:text>
        </bpmn:textAnnotation>
        <bpmn:association id="Association_1e3mv9o" associationDirection="None" sourceRef="Gateway_0cpsjl4" targetRef="TextAnnotation_0w6bym9" />
      </bpmn:subProcess>
