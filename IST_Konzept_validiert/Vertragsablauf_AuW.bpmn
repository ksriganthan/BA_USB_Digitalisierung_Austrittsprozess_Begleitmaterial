  <bpmn:collaboration id="Collaboration_0mxnk8w">
    <bpmn:participant id="Participant_15dncnp" name="Direktion Personal" processRef="Process_1er3oko" />
    <bpmn:textAnnotation id="TextAnnotation_0ojp10l">
      <bpmn:text>Vertragsablauf - AuW</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_06uu64m">
      <bpmn:text>Unter anderem wird der Austrittsschein versendet</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1htnvht">
      <bpmn:text>Die wird Liste von der Leitung Ausbildung aus dem QlickSense gezogen und geprüft. Die Bildungsverantwortlichen tragen den Vertragsablauf zu Beginn der Anstellung in die SharePoint-Liste ein.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_15homkm">
      <bpmn:text>Die SharePoint-Liste wird grundsätzlich durch HR AuW gepflegt. Die Bildungsverantwortlichen ergänzen vor Eintritt des Bearbeitungsmonats, ob ein Arbeitszeugnis oder eine Arbeitsbestätigung auszustellen ist und welche Person als VBB zuständig ist.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1ydunxr">
      <bpmn:text>- Es werden Reminder an BV gesendet, um in der Liste einzutragen wer VBB ist</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_11sbutf">
      <bpmn:text>Gemäss Interviewaussage ist unklar, welche Rolle die Bildungsverantwortlichen bei der Prüfung oder Unterzeichnung des Austrittsscheins übernehmen.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0t1j7t2" associationDirection="None" sourceRef="Activity_18w0qzb" targetRef="TextAnnotation_06uu64m" />
    <bpmn:association id="Association_0bo4t3r" associationDirection="None" sourceRef="TextAnnotation_1htnvht" targetRef="Event_10j3nzs" />
    <bpmn:association id="Association_0twkdm4" associationDirection="None" sourceRef="Activity_1c85fxk" targetRef="TextAnnotation_15homkm" />
    <bpmn:association id="Association_1vj0d29" associationDirection="None" sourceRef="Activity_1c85fxk" targetRef="TextAnnotation_1ydunxr" />
    <bpmn:association id="Association_0agnh3e" associationDirection="None" sourceRef="Event_0xxyv1g" targetRef="TextAnnotation_11sbutf" />
  </bpmn:collaboration>
