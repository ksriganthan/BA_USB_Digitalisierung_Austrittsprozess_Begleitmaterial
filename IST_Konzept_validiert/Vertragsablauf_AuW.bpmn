      <bpmn:textAnnotation id="TextAnnotation_1wt8dl9">
        <bpmn:text>MA: Grund 21 «Vertragsablauf» → Grund 25.</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_0w9vzdr" associationDirection="None" sourceRef="Activity_1ln4nkf" targetRef="TextAnnotation_1wt8dl9" />
      <bpmn:textAnnotation id="TextAnnotation_0slnfr9">
        <bpmn:text>Hier erfolgt in der Regel keine manuelle PKBS-Abmeldung, da Austritte nach Ausbildung immer im Vorhinein klar sind und gemeldet werden.</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_05dhbh7" associationDirection="None" sourceRef="Gateway_07lgzd8" targetRef="TextAnnotation_0slnfr9" />
      <bpmn:textAnnotation id="TextAnnotation_0fg92tf">
        <bpmn:text>AUSNAHME: Bei Lehrverträgen besteht keine Rückzahlungspflicht. Bei HF-Ausbildungen kann für Quereinsteigende eine Rückzahlungspflicht bestehen. Diese entfällt, wenn nach Abschluss keine Anschlussanstellung angeboten werden kann. In den übrigen Fällen bleibt die Rückzahlungspflicht gemäss Anstellungsvertrag bestehen.</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1r1sfjv" associationDirection="None" sourceRef="Gateway_0if0jau" targetRef="TextAnnotation_0fg92tf" />
      <bpmn:textAnnotation id="TextAnnotation_1nmtypp">
        <bpmn:text>Nur relevant, wenn die austretende Person pensionskassenpflichtig war.</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1dmmxkn" associationDirection="None" sourceRef="Gateway_07lgzd8" targetRef="TextAnnotation_1nmtypp" />
      <bpmn:textAnnotation id="TextAnnotation_0wugpzf">
        <bpmn:text>Bei Unklarheiten Rücksprache mit HR AuW oder BV</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1lz3s4m" associationDirection="None" sourceRef="Activity_0omo6iq" targetRef="TextAnnotation_0wugpzf" />
    </bpmn:subProcess>
