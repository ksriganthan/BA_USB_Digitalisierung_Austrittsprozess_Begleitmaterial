      <bpmn:textAnnotation id="TextAnnotation_1wt8dl9">
        <bpmn:text>Kündigungsdatum und Kündigungsgrund hinterlegen</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_0w9vzdr" associationDirection="None" sourceRef="Activity_1ln4nkf" targetRef="TextAnnotation_1wt8dl9" />
      <bpmn:textAnnotation id="TextAnnotation_10svkjy">
        <bpmn:text>Kündigung, Kündigungsgrund, (Rückzahlungs-) Vereinbarungen</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_03pv7c6">
        <bpmn:text>Falls eine Rückzahlungsvereinbarung existiert ist sie meistens nicht direkt am Ticket oder im Dossier abgelegt</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0tu7q4s">
        <bpmn:text>Der von HR Beratung mitgeteilte Rückforderungsbetrag wird durch HR Payroll bei der austretenden Person berücksichtigt bzw. zurückgefordert.</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0ak0dgt">
        <bpmn:text>HR Payroll muss im SAP, E-Dossier und in den verknüpften Tickets recherchieren</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_0fyzr7e">
        <bpmn:text>Bei einer Meldung durch HR Administration wird im Ticket zusätzlich vermerkt, ob eine Rückzahlungspflicht besteht.</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:textAnnotation id="TextAnnotation_1usnkaj">
        <bpmn:text>Gemäss HR Payroll wäre es ideal wenn die HR Beratung über das Ticket der Admin für den Austritt klar und unmissverständlich alle Infos liefert</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_0binp05" associationDirection="None" sourceRef="Gateway_1mfedc7" targetRef="TextAnnotation_1usnkaj" />
      <bpmn:association id="Association_0mt9elo" associationDirection="None" sourceRef="TextAnnotation_0fyzr7e" targetRef="Gateway_0wxdwfk" />
      <bpmn:association id="Association_061pyhf" associationDirection="None" sourceRef="Gateway_1mfedc7" targetRef="TextAnnotation_03pv7c6" />
      <bpmn:association id="Association_12jlamy" associationDirection="None" sourceRef="Activity_0fr1ssv" targetRef="TextAnnotation_0tu7q4s" />
