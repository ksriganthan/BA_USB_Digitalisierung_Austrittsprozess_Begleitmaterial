  <bpmn:collaboration id="Collaboration_0mxnk8w">
    <bpmn:participant id="Participant_15dncnp" name="Direktion Personal" processRef="Process_1er3oko" />
    <bpmn:textAnnotation id="TextAnnotation_0ojp10l">
      <bpmn:text>Kündigung MA - USB / Fonds</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1v92axl">
      <bpmn:text>Via FV/MA, per Post, Service Point, Mail, Ticket</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1befv24">
      <bpmn:text>Etwas an der Kündigung ist unklar z.B. ist FV informiert? Kündigungsfrist?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1vc590b">
      <bpmn:text>HR Beratung füllt je nach Situation das Austrittsformular aus und leitet es weiter an HR Support oder direkt an HR Administration</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0gaueou">
      <bpmn:text>Die Freistellung ersetzt den Austrittsschein nicht. HR Time Management berücksichtigt die Freistellung in PEP, wartet jedoch weiterhin auf den Austrittsschein und verbucht definitiv erst nach dessen Kontrolle.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1k6r1j1" associationDirection="None" sourceRef="Event_0vjifle" targetRef="TextAnnotation_1v92axl" />
    <bpmn:association id="Association_03qc6pg" associationDirection="None" sourceRef="Gateway_0ez2ya0" targetRef="TextAnnotation_1befv24" />
    <bpmn:association id="Association_093gpq1" associationDirection="None" sourceRef="Activity_14ctnmf" targetRef="TextAnnotation_1vc590b" />
    <bpmn:association id="Association_0kd68dq" associationDirection="None" sourceRef="Activity_0bibso0" targetRef="TextAnnotation_0gaueou" />
  </bpmn:collaboration>
